# ---------------------------------------------------------------------------
# Listing output
# ---------------------------------------------------------------------------

def check_listing(name, src, check_fn):
    global passed, failed
    try:
        code, errors = assemble(src)
        assert not code.errors, 'unexpected errors: %s' % errors
        with tempfile.NamedTemporaryFile(mode='w', suffix='.lst', delete=False) as f:
            lst_path = f.name
        try:
            assem.generate_listing(code, lst_path)
            with open(lst_path) as f:
                listing = f.read()
            check_fn(listing)
            passed += 1
        finally:
            os.unlink(lst_path)
    except Exception:
        failed += 1
        print('FAIL: %s' % name)
        traceback.print_exc()


check_listing('listing contains source text',
    '.org 0100\n    hlt\n',
    lambda lst: assert_equal('hlt' in lst, True),
)
check_listing('listing shows address',
    '.org 0100\n    hlt\n',
    lambda lst: assert_equal('0100' in lst, True),
)
check_listing('listing shows label in symbol table',
    '.org 0100\nfoo:\n    hlt\n',
    lambda lst: assert_equal('foo' in lst, True),
)
check_listing('listing shows line numbers',
    '.org 0100\n    hlt\n',
    lambda lst: assert_equal(any(c.isdigit() for c in lst), True),
)

# ---------------------------------------------------------------------------
# Golden-file tests against shipped examples
# ---------------------------------------------------------------------------

def check_example(name, asm_path, expected_txt_path):
    global passed, failed
    try:
        code = codegen.CodeGenerator()
        assem.assemble_input(code, asm_path)
        code.resolve()
        assert not code.errors, 'errors assembling %s' % asm_path
        tape = code.to_tape()
        with open(expected_txt_path) as f:
            expected = f.read()
        assert tape == expected, 'tape output differs from %s' % expected_txt_path
        passed += 1
    except Exception:
        failed += 1
        print('FAIL: %s' % name)
        traceback.print_exc()


examples_dir = os.path.join(os.path.dirname(__file__), '..', 'examples')
for _ex in ('hellorld', 'fibonacci', 'print_strings'):
    _asm = os.path.join(examples_dir, _ex + '.asm')
    _txt = os.path.join(examples_dir, _ex + '.txt')
    if os.path.exists(_asm) and os.path.exists(_txt):
        check_example('example: ' + _ex, _asm, _txt)

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------

total = passed + failed
print('%d/%d tests passed' % (passed, total))
if failed:
    sys.exit(1)
sys.exit(0)
