passed = 0
failed = 0


def assert_equal(a, b, msg=''):
    assert a == b, '%r != %r%s' % (a, b, (': ' + msg) if msg else '')


def assemble(src, extra_files=None):
    """Assemble src string; return (CodeGenerator, [error strings]).
    extra_files: dict of {filename: content} placed alongside the main file."""
    code = codegen.CodeGenerator()
    errors = []
    orig_error = code.error.__func__ if hasattr(code.error, '__func__') else None

    def capture_error(location, message):
        errors.append('%s: %s' % (location, message))
        codegen.CodeGenerator.error(code, location, message)

    code.error = capture_error

    with tempfile.TemporaryDirectory() as tmpdir:
        main_path = os.path.join(tmpdir, 'test.asm')
        with open(main_path, 'w') as f:
            f.write(src)
        if extra_files:
            for name, content in extra_files.items():
                with open(os.path.join(tmpdir, name), 'w') as f:
                    f.write(content)
        assem.assemble_input(code, main_path)
        code.resolve()

    return code, errors


def expect_ok(name, src, checks=None, extra_files=None):
    global passed, failed
    try:
        code, errors = assemble(src, extra_files)
        assert not code.errors, 'unexpected errors: %s' % errors
        for check in (checks or []):
            check(code)
        passed += 1
    except Exception:
        failed += 1
        print('FAIL: %s' % name)
        traceback.print_exc()


def expect_error(name, src, fragment, extra_files=None):
    global passed, failed
    try:
        code, errors = assemble(src, extra_files)
        assert code.errors, 'expected an error but assembly succeeded'
        combined = '\n'.join(errors)
        assert fragment in combined, \
            'expected %r in errors, got:\n%s' % (fragment, combined)
        passed += 1
    except Exception:
        failed += 1
        print('FAIL: %s' % name)
        traceback.print_exc()


def word_at(code, dec_addr):
    """Return resolved word at a decimal LGP-21 address."""
    ha = codegen.dec_to_hex_address(dec_addr)
    assert ha is not None, 'bad address %d' % dec_addr
    i = code.memory[ha]
    assert i is not None, 'nothing at address %d' % dec_addr
    return i.word


def order_of(word):
    """Return the order-code portion of a word (including MSB flag bit)."""
    return word & insn_mod.ORDER_MASK


def addr_field(word):
    return (word >> insn_mod.ADDRESS_SHIFT) & 0xFFF


