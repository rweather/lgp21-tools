# Tape output: hand-written sequence equals macro-expanded equivalent
_hand_src = '.org 0100\n    b 0200\n    a 0300\n'
_macro_src = '.macro addto &src, &dst\n    b &src\n    a &dst\n.mend\n.org 0100\n    addto 0200, 0300\n'

def _check_tape_equiv(name, src_a, src_b):
    global passed, failed
    try:
        code_a = codegen.CodeGenerator()
        with tempfile.TemporaryDirectory() as d:
            p = os.path.join(d, 'a.asm')
            open(p, 'w').write(src_a)
            assem.assemble_input(code_a, p)
        code_a.resolve()
        assert not code_a.errors

        code_b = codegen.CodeGenerator()
        with tempfile.TemporaryDirectory() as d:
            p = os.path.join(d, 'b.asm')
            open(p, 'w').write(src_b)
            assem.assemble_input(code_b, p)
        code_b.resolve()
        assert not code_b.errors

        assert code_a.to_tape() == code_b.to_tape(), \
            'tape output differs between hand-written and macro-expanded versions'
        passed += 1
    except Exception:
        failed += 1
        print('FAIL: %s' % name)
        traceback.print_exc()

_check_tape_equiv('macro: tape output matches hand-written', _hand_src, _macro_src)

