def assemble_with_macros(src, macro_files=None):
    """Assemble src with optional macro library files pre-loaded (suppressed listing)."""
    code = codegen.CodeGenerator()
    errors = []

    def capture_error(location, message):
        errors.append('%s: %s' % (location, message))
        codegen.CodeGenerator.error(code, location, message)

    code.error = capture_error

    with tempfile.TemporaryDirectory() as tmpdir:
        if macro_files:
            macro_dir = os.path.join(tmpdir, 'maclib')
            os.makedirs(macro_dir)
            code.suppress_listing = True
            for fname, content in macro_files.items():
                mac_path = os.path.join(macro_dir, fname)
                with open(mac_path, 'w') as f:
                    f.write(content)
                assem.assemble_input(code, mac_path)
            code.suppress_listing = False
            if code.errors:
                return code, errors

        main_path = os.path.join(tmpdir, 'test.asm')
        with open(main_path, 'w') as f:
            f.write(src)
        assem.assemble_input(code, main_path)
        code.resolve()

    return code, errors


def expect_ok_macros(name, src, macro_files=None, checks=None):
    global passed, failed
    try:
        code, errors = assemble_with_macros(src, macro_files)
        assert not code.errors, 'unexpected errors: %s' % errors
        for check in (checks or []):
            check(code)
        passed += 1
    except Exception:
        failed += 1
        print('FAIL: %s' % name)
        traceback.print_exc()


