#!/usr/bin/python3
#
# Test suite for the LGP-21 assembler.

import os
import sys
import tempfile
import traceback

sys.path.insert(0, os.path.join(os.path.dirname(__file__)))

import lgp21.assem as assem
import lgp21.codegen as codegen
import lgp21.insn as insn_mod

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

passed = 0
failed = 0


def assert_equal(a, b, msg=''):
    assert a == b, '%r != %r%s' % (a, b, (': ' + msg) if msg else '')


def assemble(src, extra_files=None):
    """Assemble src string; return (CodeGenerator, [error strings]).
    extra_files: dict of {filename: content} placed alongside the main file."""
    code = codegen.CodeGenerator()
    errors = []
    orig_error = code.error.__func__ if hasattr(code.error, '__func__') else None

    def capture_error(location, message):
        errors.append('%s: %s' % (location, message))
        codegen.CodeGenerator.error(code, location, message)

    code.error = capture_error

    with tempfile.TemporaryDirectory() as tmpdir:
        main_path = os.path.join(tmpdir, 'test.asm')
        with open(main_path, 'w') as f:
            f.write(src)
        if extra_files:
            for name, content in extra_files.items():
                with open(os.path.join(tmpdir, name), 'w') as f:
                    f.write(content)
        assem.assemble_input(code, main_path)
        code.resolve()

    return code, errors


def expect_ok(name, src, checks=None, extra_files=None):
    global passed, failed
    try:
        code, errors = assemble(src, extra_files)
        assert not code.errors, 'unexpected errors: %s' % errors
        for check in (checks or []):
            check(code)
        passed += 1
    except Exception:
        failed += 1
        print('FAIL: %s' % name)
        traceback.print_exc()


def expect_error(name, src, fragment, extra_files=None):
    global passed, failed
    try:
        code, errors = assemble(src, extra_files)
        assert code.errors, 'expected an error but assembly succeeded'
        combined = '\n'.join(errors)
        assert fragment in combined, \
            'expected %r in errors, got:\n%s' % (fragment, combined)
        passed += 1
    except Exception:
        failed += 1
        print('FAIL: %s' % name)
        traceback.print_exc()


def word_at(code, dec_addr):
    """Return resolved word at a decimal LGP-21 address."""
    ha = codegen.dec_to_hex_address(dec_addr)
    assert ha is not None, 'bad address %d' % dec_addr
    i = code.memory[ha]
    assert i is not None, 'nothing at address %d' % dec_addr
    return i.word


def order_of(word):
    """Return the order-code portion of a word (including MSB flag bit)."""
    return word & insn_mod.ORDER_MASK


def addr_field(word):
    return (word >> insn_mod.ADDRESS_SHIFT) & 0xFFF


# ---------------------------------------------------------------------------
# Opcodes and aliases
# ---------------------------------------------------------------------------

OPCODE_CASES = [
    ('a',    insn_mod.ADD),
    ('add',  insn_mod.ADD),
    ('b',    insn_mod.BRING),
    ('ld',   insn_mod.BRING),
    ('c',    insn_mod.CLEAR),
    ('clr',  insn_mod.CLEAR),
    ('stc',  insn_mod.CLEAR),
    ('d',    insn_mod.DIV),
    ('div',  insn_mod.DIV),
    ('e',    insn_mod.EXTRACT),
    ('and',  insn_mod.EXTRACT),
    ('h',    insn_mod.HOLD),
    ('st',   insn_mod.HOLD),
    ('m',    insn_mod.MUL_H),
    ('mulh', insn_mod.MUL_H),
    ('n',    insn_mod.MUL_L),
    ('mull', insn_mod.MUL_L),
    ('r',    insn_mod.RETURN),
    ('sret', insn_mod.RETURN),
    ('s',    insn_mod.SUB),
    ('sub',  insn_mod.SUB),
    ('t',    insn_mod.COND),
    ('jn',   insn_mod.COND),
    ('-t',   insn_mod.CTRL),
    ('jnt',  insn_mod.CTRL),
    ('u',    insn_mod.UNCOND),
    ('jmp',  insn_mod.UNCOND),
    ('y',    insn_mod.STORE),
    ('sta',  insn_mod.STORE),
    ('z',    insn_mod.STOP),
    ('-z',   insn_mod.OVERFLOW),
    ('ovr',  insn_mod.OVERFLOW),
]

for _mnem, _expected_order in OPCODE_CASES:
    def _check(code, mnem=_mnem, expected=_expected_order):
        assert_equal(order_of(word_at(code, 100)), expected, mnem)
    expect_ok('opcode %s' % _mnem,
              '.org 0100\n    %s 0200\n' % _mnem,
              [_check])

# Implicit-operand opcodes (no user operand allowed)
for _mnem, _expected_order in [('hlt', insn_mod.STOP), ('nop', insn_mod.STOP),
                                 ('shl6', insn_mod.INPUT6), ('shl4', insn_mod.INPUT4)]:
    def _check(code, expected=_expected_order):
        assert_equal(order_of(word_at(code, 100)), expected)
    expect_ok('opcode %s (implicit)' % _mnem,
              '.org 0100\n    %s\n' % _mnem,
              [_check])

# Default-operand opcodes assemble without error when operand is omitted
for _mnem in ('in6', 'in4', 'pr6', 'pr4'):
    expect_ok('opcode %s default operand' % _mnem,
              '.org 0100\n    %s\n' % _mnem)

# Case-insensitivity of opcodes
expect_ok('opcode uppercase', '.org 0100\n    ADD 0200\n', [
    lambda code: assert_equal(order_of(word_at(code, 100)), insn_mod.ADD),
])
expect_ok('opcode mixed case', '.org 0100\n    Add 0200\n', [
    lambda code: assert_equal(order_of(word_at(code, 100)), insn_mod.ADD),
])

# Operand resolves to correct address field
expect_ok('instruction address field', '.org 0100\n    b 0300\n', [
    lambda code: assert_equal(addr_field(word_at(code, 100)),
                              codegen.dec_to_hex_address(300)),
])

# ---------------------------------------------------------------------------
# Directives
# ---------------------------------------------------------------------------

# .org
expect_ok('.org places code at correct address', '.org 0500\n    hlt\n', [
    lambda code: assert_equal(code.memory[codegen.dec_to_hex_address(500)] is not None, True),
    lambda code: assert_equal(code.memory[codegen.dec_to_hex_address(100)], None),
])

# .entry
expect_ok('.entry sets entry point', '.org 0100\nstart:\n    hlt\n.entry start\n', [
    lambda code: assert_equal(code.entry_point_address,
                              codegen.dec_to_hex_address(100)),
])

# .dw with various literal types
expect_ok('.dw decimal integer', '.org 0100\n    .dw #42\n', [
    lambda code: assert_equal(word_at(code, 100), 42),
])
expect_ok('.dw negative integer', '.org 0100\n    .dw #-1\n', [
    lambda code: assert_equal(word_at(code, 100), 0xFFFFFFFF),
])
expect_ok('.dw hex $', '.org 0100\n    .dw $DEADBEEF\n', [
    lambda code: assert_equal(word_at(code, 100), 0xDEADBEEF),
])
expect_ok('.dw multiple values', '.org 0100\n    .dw #1, #2, #3\n', [
    lambda code: assert_equal(word_at(code, 100), 1),
    lambda code: assert_equal(word_at(code, 101), 2),
    lambda code: assert_equal(word_at(code, 102), 3),
])
expect_ok('.dw float 0.5', '.org 0100\n    .dw 0.5\n', [
    lambda code: assert_equal(word_at(code, 100), 0x40000000),
])
expect_ok('.dw float -0.5', '.org 0100\n    .dw -0.5\n', [
    lambda code: assert_equal(word_at(code, 100), 0xC0000000),
])
expect_ok('.dw address label', '.org 0100\ntgt:\n    hlt\n.org 0200\n    .dw tgt\n', [
    lambda code: assert_equal(
        addr_field(word_at(code, 200)),
        codegen.dec_to_hex_address(100)),
])

# .noemit / .emit
expect_ok('.noemit reserves space without emitting', (
    '.org 0100\n.noemit\nvar:\n    .dw #0\n.emit\nstart:\n    hlt\n'), [
    lambda code: assert_equal(code.memory[codegen.dec_to_hex_address(100)].emit, False),
    lambda code: assert_equal(code.memory[codegen.dec_to_hex_address(101)].emit, True),
])

# .include
expect_ok('.include assembles external file',
    '.org 0100\n.include lib.asm\n',
    [lambda code: assert_equal(order_of(word_at(code, 100)), insn_mod.STOP)],
    extra_files={'lib.asm': '    hlt\n'},
)
expect_ok('.include path is relative to including file',
    '.org 0100\n.include sub.asm\n    hlt\n',
    [lambda code: assert_equal(code.memory[codegen.dec_to_hex_address(100)] is not None, True)],
    extra_files={'sub.asm': '    b 0200\n'},
)

# ---------------------------------------------------------------------------
# Labels
# ---------------------------------------------------------------------------

expect_ok('label binds to current PC', '.org 0200\nfoo:\n    hlt\n', [
    lambda code: assert_equal(code.labels['foo']['address'],
                              codegen.dec_to_hex_address(200)),
])
expect_ok('label on same line as instruction', '.org 0200\nfoo: hlt\n', [
    lambda code: assert_equal(code.labels['foo']['address'],
                              codegen.dec_to_hex_address(200)),
])
expect_ok('address equate used as operand', 'scratch = 0300\n.org 0100\n    b scratch\n', [
    lambda code: assert_equal(addr_field(word_at(code, 100)),
                              codegen.dec_to_hex_address(300)),
])
expect_ok('integer equate stored in symbol table', 'x = #42\n.org 0100\n    hlt\n', [
    lambda code: assert_equal(code.labels['x']['value'], 42),
])
expect_ok('forward reference resolves', '.org 0100\n    b target\ntarget:\n    hlt\n', [
    lambda code: assert_equal(addr_field(word_at(code, 100)),
                              codegen.dec_to_hex_address(101)),
])
expect_ok('address label (.NNNN:) sets origin', '.0300: hlt\n', [
    lambda code: assert_equal(order_of(word_at(code, 300)), insn_mod.STOP),
    lambda code: assert_equal(code.memory[0], None),
])

