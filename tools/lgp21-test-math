#!/usr/bin/python3
#
# Test that the LGP-21 math routines work.

import sys
import lgp21.machine as machine

def check(actual, expected_value, expected_overflow):
    if actual[0] != expected_value:
        raise ValueError('0x%x != 0x%x' % (actual[0], expected_value))
    if actual[1] != expected_overflow:
        raise ValueError('overflow mismatch')

def signed_to_unsigned(x):
    if x < 0:
        x = -x
        x = (x & 0xFFFFFFFF) ^ 0xFFFFFFFF
        x += 1
    return x & 0xFFFFFFFF

def check_add(x, y, expected):
    z = x + y
    if z < -0x80000000 or z > 0x7FFFFFFF:
        expected_overflow = True
    else:
        expected_overflow = False
    expected_value = signed_to_unsigned(expected)
    check(machine.add(signed_to_unsigned(x), signed_to_unsigned(y)), expected_value, expected_overflow)

def check_sub(x, y, expected):
    z = x - y
    if z < -0x80000000 or z > 0x7FFFFFFF:
        expected_overflow = True
    else:
        expected_overflow = False
    expected_value = signed_to_unsigned(expected)
    check(machine.sub(signed_to_unsigned(x), signed_to_unsigned(y)), expected_value, expected_overflow)

def check_mul(x, y, expected_high, expected_low):
    expected_high_value = signed_to_unsigned(expected_high)
    expected_low_value = signed_to_unsigned(expected_low)
    check((machine.multiply(signed_to_unsigned(x), signed_to_unsigned(y), True), False), expected_high_value, False)
    check((machine.multiply(signed_to_unsigned(x), signed_to_unsigned(y), False), False), expected_low_value, False)

def check_div(x, y, expected_value, expected_overflow=False):
    check(machine.divide(signed_to_unsigned(x), signed_to_unsigned(y)), signed_to_unsigned(expected_value), expected_overflow)

check_add(1, 1, 2)      # 1 + 1 = 2
check_add(1, -2, -1)    # 1 + -2 = -1
check_add(-13, 27, 14)  # -13 + 27 = 14
check_add(0x7FFF0000, 0xFFFF, 0x7FFFFFFF)
check_add(0x7FFF0001, 0xFFFF, -0x80000000)
check_add(0x7FFFFFFF, -0x80000000, -1)

check_sub(1, 1, 0)      # 1 - 1 = 0
